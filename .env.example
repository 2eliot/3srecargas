# ─── Base ────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-segura
DATABASE_URL=sqlite:///data/app.db
DATA_DIR=data

# ─── Admin inicial ───────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── Automatización VPS (bot de recargas) ────────────────────────────────────
AUTOMATION_SERVICE_URL=http://localhost:8000
VPS_REDEEM_URL=http://localhost:8000/redeem
VPS_TIMEOUT=120
VPS_COUNTRY=Venezuela
VPS_FULL_NAME=Usuario Recarga
VPS_BIRTH_DATE=01/01/1995

# ─── Revendedores Whitelabel API ─────────────────────────────────────────────
REVENDEDORES_BASE_URL=
REVENDEDORES_API_KEY=

# ─── Verificación de ID (scraping) ──────────────────────────────────────────
SCRAPE_ENABLED=true

# ─── Correo (SMTP) ──────────────────────────────────────────────────────────
# Para Gmail: usa una "contraseña de aplicación" (no tu contraseña normal).
# Actívala en: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_DEFAULT_SENDER=tu-correo@gmail.com
MAIL_BRAND_NAME=3S Recargas

# ─── Soporte y notificaciones ────────────────────────────────────────────────
SUPPORT_EMAIL=soporte@3srecargas.com
SUPPORT_WHATSAPP=https://wa.me/58412XXXXXXX
ADMIN_NOTIFY_EMAIL=admin@3srecargas.com
